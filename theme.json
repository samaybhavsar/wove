{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "660px",
			"wideSize": "960px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"custom": true,
			"customGradient": false,
			"customDuotone": false,
			"palette": [
				{ "slug": "base", "name": "Paper", "color": "#fbfaf7" },
				{ "slug": "contrast", "name": "Ink", "color": "#1b1b18" },
				{ "slug": "muted", "name": "Muted", "color": "#6d6a62" },
				{ "slug": "rule", "name": "Rule", "color": "#e4e1d9" },
				{ "slug": "faint", "name": "Faint", "color": "#f1efe9" }
			]
		},
		"typography": {
			"fluid": false,
			"defaultFontSizes": false,
			"customFontSize": true,
			"lineHeight": true,
			"letterSpacing": true,
			"dropCap": false,
			"writingMode": false,
			"fontFamilies": [
				{
					"slug": "serif",
					"name": "Newsreader",
					"fontFamily": "Newsreader, Georgia, 'Times New Roman', serif",
					"fontFace": [
						{
							"fontFamily": "Newsreader",
							"fontStyle": "normal",
							"fontWeight": "200 800",
							"fontStretch": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/newsreader-latin-standard-normal.woff2" ]
						},
						{
							"fontFamily": "Newsreader",
							"fontStyle": "italic",
							"fontWeight": "200 800",
							"fontStretch": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/newsreader-latin-standard-italic.woff2" ]
						}
					]
				},
				{
					"slug": "mono",
					"name": "Monospace",
					"fontFamily": "ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, 'Liberation Mono', monospace"
				}
			],
			"fontSizes": [
				{ "slug": "small", "name": "Small", "size": "0.875rem", "fluid": false },
				{ "slug": "medium", "name": "Medium", "size": "clamp(1rem, 0.945rem + 0.225vw, 1.125rem)", "fluid": false },
				{ "slug": "large", "name": "Large", "size": "clamp(1.2rem, 1.11rem + 0.371vw, 1.406rem)", "fluid": false },
				{ "slug": "x-large", "name": "Extra Large", "size": "clamp(1.44rem, 1.301rem + 0.571vw, 1.758rem)", "fluid": false },
				{ "slug": "xx-large", "name": "Huge", "size": "clamp(1.728rem, 1.522rem + 0.844vw, 2.197rem)", "fluid": false },
				{ "slug": "display", "name": "Display", "size": "clamp(2.074rem, 1.779rem + 1.21vw, 2.747rem)", "fluid": false }
			]
		},
		"spacing": {
			"units": [ "px", "em", "rem", "vh", "vw", "%" ],
			"spacingScale": { "steps": 0 },
			"spacingSizes": [
				{ "slug": "20", "name": "1", "size": "0.75rem" },
				{ "slug": "30", "name": "2", "size": "1.25rem" },
				{ "slug": "40", "name": "3", "size": "2rem" },
				{ "slug": "50", "name": "4", "size": "3rem" },
				{ "slug": "60", "name": "5", "size": "4.5rem" },
				{ "slug": "70", "name": "6", "size": "6.5rem" },
				{ "slug": "80", "name": "7", "size": "9rem" }
			]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"spacing": {
			"blockGap": "1.5rem",
			"padding": {
				"top": "0",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--40)",
				"right": "var(--wp--preset--spacing--40)"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--serif)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"fontWeight": "400",
			"lineHeight": "1.6",
			"letterSpacing": "-0.003em"
		},
		"elements": {
			"link": {
				"color": { "text": "var(--wp--preset--color--contrast)" },
				"typography": { "textDecoration": "underline" },
				":hover": {
					"color": { "text": "var(--wp--preset--color--muted)" }
				},
				":focus": {
					"color": { "text": "var(--wp--preset--color--muted)" }
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "500",
					"lineHeight": "1.25",
					"letterSpacing": "-0.01em"
				}
			},
			"h1": { "typography": { "fontSize": "var(--wp--preset--font-size--xx-large)", "lineHeight": "1.12", "letterSpacing": "-0.02em" } },
			"h2": { "typography": { "fontSize": "var(--wp--preset--font-size--x-large)", "lineHeight": "1.2", "letterSpacing": "-0.015em" } },
			"h3": { "typography": { "fontSize": "var(--wp--preset--font-size--large)", "lineHeight": "1.3", "letterSpacing": "-0.01em" } },
			"h4": { "typography": { "fontSize": "var(--wp--preset--font-size--large)", "fontWeight": "600", "lineHeight": "1.3", "letterSpacing": "-0.01em" } },
			"h5": { "typography": { "fontSize": "var(--wp--preset--font-size--medium)", "fontWeight": "600", "lineHeight": "1.4", "letterSpacing": "-0.003em" } },
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "600",
					"textTransform": "uppercase",
					"letterSpacing": "0.1em",
					"lineHeight": "1.4"
				},
				"color": { "text": "var(--wp--preset--color--muted)" }
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--contrast)",
					"text": "var(--wp--preset--color--base)"
				},
				"border": { "radius": "2px" },
				"spacing": { "padding": { "top": "0.6rem", "bottom": "0.6rem", "left": "1.25rem", "right": "1.25rem" } },
				"typography": { "fontSize": "var(--wp--preset--font-size--small)", "textDecoration": "none" },
				":hover": {
					"color": { "background": "var(--wp--preset--color--muted)", "text": "var(--wp--preset--color--base)" }
				},
				":focus": {
					"color": { "background": "var(--wp--preset--color--muted)", "text": "var(--wp--preset--color--base)" }
				}
			},
			"caption": {
				"color": { "text": "var(--wp--preset--color--muted)" },
				"typography": { "fontSize": "var(--wp--preset--font-size--small)", "fontStyle": "italic" }
			}
		},
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontSize": "1.125rem",
					"fontWeight": "600",
					"letterSpacing": "-0.01em"
				},
				"elements": {
					"link": { "typography": { "textDecoration": "none" } }
				}
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "500",
					"lineHeight": "1.12",
					"letterSpacing": "-0.02em"
				}
			},
			"core/post-excerpt": {
				"color": { "text": "var(--wp--preset--color--muted)" },
				"typography": { "lineHeight": "1.6" }
			},
			"core/post-date": {
				"color": { "text": "var(--wp--preset--color--muted)" },
				"typography": { "fontSize": "var(--wp--preset--font-size--small)" }
			},
			"core/quote": {
				"border": {
					"left": { "color": "var(--wp--preset--color--rule)", "width": "2px", "style": "solid" }
				},
				"spacing": { "padding": { "left": "var(--wp--preset--spacing--40)" } },
				"typography": { "fontStyle": "italic", "fontSize": "var(--wp--preset--font-size--large)", "lineHeight": "1.5" }
			},
			"core/separator": {
				"color": { "text": "var(--wp--preset--color--rule)" }
			},
			"core/navigation": {
				"typography": {
					"fontSize": "0.9375rem",
					"letterSpacing": "0.01em"
				},
				"elements": {
					"link": { "typography": { "textDecoration": "none" } }
				}
			},
			"core/code": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--mono)", "fontSize": "var(--wp--preset--font-size--small)" },
				"color": { "background": "var(--wp--preset--color--faint)" },
				"border": { "radius": "4px" },
				"spacing": { "padding": { "top": "1rem", "bottom": "1rem", "left": "1.25rem", "right": "1.25rem" } }
			},
			"core/pullquote": {
				"typography": { "fontStyle": "italic" },
				"border": { "top": { "color": "var(--wp--preset--color--rule)", "width": "1px", "style": "solid" }, "bottom": { "color": "var(--wp--preset--color--rule)", "width": "1px", "style": "solid" } }
			},
			"core/list": {
				"spacing": { "padding": { "left": "var(--wp--preset--spacing--40)" } },
				"typography": { "lineHeight": "1.6" }
			},
			"core/image": {
				"spacing": { "margin": { "top": "var(--wp--preset--spacing--40)", "bottom": "var(--wp--preset--spacing--40)" } }
			},
			"core/preformatted": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--mono)", "fontSize": "var(--wp--preset--font-size--small)" },
				"color": { "background": "var(--wp--preset--color--faint)" },
				"border": { "radius": "4px" },
				"spacing": { "padding": { "top": "1rem", "bottom": "1rem", "left": "1.25rem", "right": "1.25rem" } }
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"customTemplates": []
}
